{
  "private": true,
  "name": "the-commons-game",
  "version": "1.0.0",
  "description": "✉️ Sealed daily social-dilemma game — commit one hidden choice, learn the collective verdict only tomorrow (Devvit)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edycutjong/the-commons.git"
  },
  "homepage": "https://github.com/edycutjong/the-commons#readme",
  "bugs": {
    "url": "https://github.com/edycutjong/the-commons/issues"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run type-check && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --silent",
    "seed:local": "node scripts/seed-local.mjs",
    "bench": "node scripts/bench.mjs",
    "check": "node scripts/check_submission_readiness.mjs",
    "check:submission": "node scripts/check_submission_readiness.mjs",
    "audit": "npm audit --audit-level=high",
    "ci": "npm run lint && npm run type-check && npm run test:coverage && npm run build && npm run bench && npm run check:submission -- --fast",
    "release": "semantic-release"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.8",
    "@devvit/web": "0.13.8",
    "@hono/node-server": "^2.0.5",
    "devvit": "0.13.8",
    "hono": "^4.12.27",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.5",
    "globals": "^16.5.0",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.7",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "tmp": "^0.2.7",
    "ws": "^8.21.0",
    "protobufjs": "^7.6.5",
    "js-yaml": "^4.3.0"
  }
}
